{
  "name": "api.mabell",
  "description": "API for the Mabell project",
  "author": "imkzvd@gmail.com",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nest build",
    "build:admin": "nest build admin",
    "build:client": "nest build client",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:admin:dev": "nest start admin --watch",
    "start:client:dev": "nest start client --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:admin:prod": "node dist/apps/admin/apps/admin/src/main",
    "start:client:prod": "node dist/apps/client/apps/client/src/main --env-file .env.client",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@babel/runtime": "^7.27.1",
    "@faker-js/faker": "^9.9.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.2",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/mongoose": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.2.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "generate-password": "^1.7.1",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "typesense": "^2.0.3",
    "utility-types": "^3.11.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.3.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lerna": "^8.2.3",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/libs/",
      "<rootDir>/apps/"
    ],
    "moduleNameMapper": {
      "^@api.mabell/cache(|/.*)$": "<rootDir>/libs/cache/$1",
      "^@api.mabell/core(|/.*)$": "<rootDir>/libs/core/$1",
      "^@api.mabell/cqrs(|/.*)$": "<rootDir>/libs/cqrs/$1",
      "^@api.mabell/db(|/.*)$": "<rootDir>/libs/db/$1",
      "^@api.mabell/event-bus(|/.*)$": "<rootDir>/libs/event-bus/$1",
      "^@api.mabell/file-storage(|/.*)$": "<rootDir>/libs/file-storage/$1",
      "^@api.mabell/jwt(|/.*)$": "<rootDir>/libs/jwt/$1",
      "^@api.mabell/password(|/.*)$": "<rootDir>/libs/password/$1",
      "^@api.mabell/random-id(|/.*)$": "<rootDir>/libs/random-id/$1",
      "^@api.mabell/search(|/.*)$": "<rootDir>/libs/search/$1",
      "^@api.mabell/shared(|/.*)$": "<rootDir>/libs/shared/$1"
    }
  }
}
