{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@core": ["libs/core/src"],
      "@core/*": ["libs/core/src/*"],
      "@infrastructure/command-bus": ["libs/command-bus/src"],
      "@infrastructure/command-bus/*": ["libs/command-bus/src/*"],
      "@infrastructure/event-bus": ["libs/event-bus/src"],
      "@infrastructure/event-bus/*": ["libs/event-bus/src/*"],
      "@infrastructure/file-storage": ["libs/file-storage/src"],
      "@infrastructure/file-storage/*": ["libs/file-storage/src/*"],
      "@infrastructure/jwt": ["libs/jwt/src"],
      "@infrastructure/jwt/*": ["libs/jwt/src/*"],
      "@infrastructure/mongoose": ["libs/mongoose/src"],
      "@infrastructure/mongoose/*": ["libs/mongoose/src/*"],
      "@infrastructure/password": ["libs/password/src"],
      "@infrastructure/password/*": ["libs/password/src/*"],
      "@infrastructure/query-bus": ["libs/query-bus/src"],
      "@infrastructure/query-bus/*": ["libs/query-bus/src/*"],
      "@infrastructure/random-id": ["libs/random-id/src"],
      "@infrastructure/random-id/*": ["libs/random-id/src/*"],
      "@infrastructure/redis": ["libs/redis/src"],
      "@infrastructure/redis/*": ["libs/redis/src/*"],
      "@infrastructure/typesense": ["libs/typesense/src"],
      "@infrastructure/typesense/*": ["libs/typesense/src/*"],
      "@shared": ["libs/shared/src"],
      "@shared/*": ["libs/shared/src/*"],
      "@types": ["libs/types/src"],
      "@types/*": ["libs/types/src/*"]
    }
  }
}
