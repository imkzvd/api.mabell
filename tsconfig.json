{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "paths": {
      "@api.mabell/core": ["libs/core"],
      "@api.mabell/event-bus": ["libs/event-bus"],
      "@api.mabell/file-storage": ["libs/file-storage"],
      "@api.mabell/jwt": ["libs/jwt"],
      "@api.mabell/db": ["libs/db"],
      "@api.mabell/cqrs": ["libs/cqrs"],
      "@api.mabell/password": ["libs/password"],
      "@api.mabell/random-id": ["libs/random-id"],
      "@api.mabell/cache": ["libs/cache"],
      "@api.mabell/shared": ["libs/shared"],
      "@api.mabell/search": ["libs/search"]
    }
  }
}
