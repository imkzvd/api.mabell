{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "@core": "<rootDir>/../libs/core/src",
    "@core/(.*)": "<rootDir>/../libs/core/src/$1",
    "@infrastructure/event-bus": "<rootDir>/../libs/event-bus/src",
    "@infrastructure/event-bus/(.*)": "<rootDir>/../libs/event-bus/src/$1",
    "@infrastructure/file-storage": "<rootDir>/../libs/file-storage/src",
    "@infrastructure/file-storage/(.*)": "<rootDir>/../libs/file-storage/src/$1",
    "@infrastructure/jwt": "<rootDir>/../libs/jwt/src",
    "@infrastructure/jwt/(.*)": "<rootDir>/../libs/jwt/src/$1",
    "@infrastructure/mongoose": "<rootDir>/../libs/mongoose/src",
    "@infrastructure/mongoose/(.*)": "<rootDir>/../libs/mongoose/src/$1",
    "@infrastructure/password": "<rootDir>/../libs/password/src",
    "@infrastructure/password/(.*)": "<rootDir>/../libs/password/src/$1",
    "@infrastructure/random-id": "<rootDir>/../libs/random-id/src",
    "@infrastructure/random-id/(.*)": "<rootDir>/../libs/random-id/src/$1",
    "@infrastructure/redis": "<rootDir>/../libs/redis/src",
    "@infrastructure/redis/(.*)": "<rootDir>/../libs/redis/src/$1",
    "@infrastructure/typesense": "<rootDir>/../libs/typesense/src",
    "@infrastructure/typesense/(.*)": "<rootDir>/../libs/typesense/src/$1"
  }
}