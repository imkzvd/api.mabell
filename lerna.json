{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "npmClient": "npm",
  "version": "0.1.0",
  "push": false,
  "packages": ["apps/*", "libs/*"],
  "command": {
    "version": {
      "allowBranch": "feature/*",
      "message": "chore(release): updated packages",
      "includeMergedTags": true
    }
  }
}
