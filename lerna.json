{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "npmClient": "npm",
  "version": "1.0.0-alpha.3",
  "push": false,
  "packages": ["apps/*", "libs/*"],
  "command": {
    "version": {
      "allowBranch": "release/*",
      "message": "chore(release): v%v",
      "tagVersionPrefix": "lv"
    }
  }
}
