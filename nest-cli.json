    "event-bus": {
      "type": "library",
      "root": "libs/event-bus",
      "entryFile": "index",
      "sourceRoot": "libs/event-bus/src",
      "compilerOptions": {
        "tsConfigPath": "libs/event-bus/tsconfig.lib.json"
      }
    },
    "file-storage": {
      "type": "library",
      "root": "libs/file-storage",
      "entryFile": "index",
      "sourceRoot": "libs/file-storage/src",
      "compilerOptions": {
        "tsConfigPath": "libs/file-storage/tsconfig.lib.json"
      }
    },
    "jwt": {
      "type": "library",
